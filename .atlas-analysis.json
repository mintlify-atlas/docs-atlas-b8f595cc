  "keyFeatures": [
    "AI script analysis - automatically parse novels, extract characters, scenes, and plot structure",
    "Character & scene generation - AI-generated consistent character appearances and scene images",
    "Storyboard video production - automated shot generation and video composition",
    "Multi-character AI voiceover - voice synthesis with emotion and character matching",
    "Task queue system - BullMQ-based asynchronous task processing with retry logic",
    "Billing & usage tracking - real-time cost tracking per AI model and action",
    "Asset management - global character, location, and voice library",
    "Video editor integration - built-in timeline editor for final video assembly"
  ],
  "publicApiSurface": [
    "POST /api/projects - Create new film project",
    "POST /api/novel-promotion/analyze-novel - Analyze novel text and extract structure",
    "POST /api/novel-promotion/build-storyboard - Generate storyboard from screenplay",
    "POST /api/novel-promotion/generate-voice - Synthesize character voiceovers",
    "POST /api/asset-hub/characters - Manage character assets",
    "POST /api/asset-hub/locations - Manage scene/location assets",
    "GET /api/tasks/events - Stream task progress events (SSE)",
    "POST /api/user/api-config - Configure AI provider API keys",
    "Task system - image, text, video, voice worker queues",
    "GraphRun workflow engine - multi-step AI workflow orchestration"
  ]
